# PPE Detection frontend — environment configuration.
# Copy to ".env" and adjust for your deployment. All vars are optional;
# the defaults below match a backend running locally on port 5000.

# REST + Server-Sent-Events base URL.
VITE_API_BASE_URL=http://127.0.0.1:5000

# WebSocket base URL (live video). If omitted it is derived from the API URL
# by swapping http(s) -> ws(s).
VITE_WS_BASE_URL=ws://127.0.0.1:5000

# How often live snapshots (camera status) are re-polled, in milliseconds.
VITE_POLL_INTERVAL_MS=15000
