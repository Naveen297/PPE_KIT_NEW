# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=PPE Detection System
APP_URL=http://localhost:5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ppe_detection_system
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Authentication
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRE=30d

# Redis (for caching and queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,video/mp4

# AWS S3 (optional, for cloud storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@mahindra-ppe.com

# SMS (Twilio or similar)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AI Model Configuration
AI_MODEL_API_URL=http://localhost:8000
AI_MODEL_API_KEY=
AI_CONFIDENCE_THRESHOLD=0.85

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Socket.IO
SOCKET_ENABLED=true
SOCKET_CORS_ORIGIN=*

# Monitoring & Analytics
ENABLE_METRICS=true
METRICS_PORT=9090

# Camera Stream Settings
RTSP_TIMEOUT=30000
CAMERA_HEALTH_CHECK_INTERVAL=60000

# Report Generation
REPORT_RETENTION_DAYS=90
REPORT_GENERATION_QUEUE_CONCURRENCY=2

# Alerts
ALERT_RETRY_ATTEMPTS=3
ALERT_RETRY_DELAY=5000

# Feature Flags
ENABLE_REAL_TIME_DETECTION=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=true
