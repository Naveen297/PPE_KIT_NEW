// DBML - Database Markup Language for ER Diagram
// PPE Detection System - Mahindra Manufacturing
// Use this with dbdiagram.io or VS Code ERD extensions

Project PPE_Detection_System {
  database_type: 'PostgreSQL'
  Note: '''
    # PPE Detection System Database
    Safety monitoring system for Mahindra manufacturing plants
    Tracks PPE compliance, incidents, and generates analytics
  '''
}

// ===============================================
// USER MANAGEMENT MODULE
// ===============================================

Table users {
  id uuid [pk, increment]
  email varchar(255) [unique, not null]
  password_hash varchar(255) [not null]
  first_name varchar(100) [not null]
  last_name varchar(100) [not null]
  phone_number varchar(20)
  role_id uuid [not null, ref: > roles.id]
  plant_id uuid [ref: > plants.id]
  is_active boolean [default: true]
  last_login timestamp
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    email [unique]
    role_id
    plant_id
  }

  Note: 'System users: operators, supervisors, admins'
}

Table roles {
  id uuid [pk, increment]
  name varchar(50) [unique, not null, note: 'admin, supervisor, operator, viewer, auditor']
  description text
  permissions json
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Note: 'User roles with permissions'
}

// ===============================================
// PLANT INFRASTRUCTURE MODULE
// ===============================================

Table plants {
  id uuid [pk, increment]
  name varchar(255) [not null]
  code varchar(10) [unique, not null, note: 'Plant code e.g. MPP']
  location varchar(255) [not null]
  address text
  city varchar(100)
  state varchar(100)
  country varchar(100) [default: 'India']
  timezone varchar(50) [default: 'Asia/Kolkata']
  is_active boolean [default: true]
  total_employees int
  operational_hours json
  contact_person varchar(100)
  contact_email varchar(255)
  contact_phone varchar(20)
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    code [unique]
    is_active
  }

  Note: 'Manufacturing plants/facilities'
}

Table zones {
  id uuid [pk, increment]
  plant_id uuid [not null, ref: > plants.id]
  name varchar(255) [not null, note: 'e.g. Assembly Line A']
  code varchar(20) [not null]
  description text
  zone_type varchar(50) [note: 'production, assembly, welding, warehouse']
  risk_level varchar(20) [note: 'low, medium, high, critical']
  required_ppe json [note: 'Array of required PPE item IDs']
  area_sqm decimal(10,2)
  max_capacity int
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    plant_id
    (plant_id, code) [unique]
    zone_type
    risk_level
  }

  Note: 'Zones/areas within plants'
}

Table cameras {
  id uuid [pk, increment]
  zone_id uuid [not null, ref: > zones.id]
  name varchar(255) [not null]
  camera_code varchar(50) [unique, not null]
  ip_address varchar(45)
  rtsp_url varchar(512)
  http_url varchar(512)
  location_description text
  position_x decimal(10,2)
  position_y decimal(10,2)
  camera_type varchar(50) [note: 'fixed, PTZ, dome']
  resolution varchar(20) [note: '1920x1080']
  fps int [default: 30]
  status varchar(20) [default: 'active', note: 'active, inactive, maintenance, error']
  last_heartbeat timestamp
  uptime_percentage decimal(5,2)
  ai_model_version varchar(20)
  confidence_threshold decimal(3,2) [default: 0.85]
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    camera_code [unique]
    zone_id
    status
  }

  Note: 'Surveillance cameras for PPE detection'
}

// ===============================================
// PPE ITEMS MODULE
// ===============================================

Table ppe_items {
  id uuid [pk, increment]
  name varchar(100) [not null, note: 'e.g. Safety Helmet']
  code varchar(20) [unique, not null, note: 'e.g. HELMET']
  description text
  category varchar(50) [note: 'head, hand, body, foot, face, respiratory']
  priority varchar(20) [not null, note: 'critical, high, medium, low']
  color_code varchar(7) [note: 'Hex color for UI']
  icon varchar(50)
  is_mandatory boolean [default: true]
  compliance_weight decimal(3,2) [note: '0-1, weight in compliance calculation']
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    code [unique]
    category
    priority
  }

  Note: 'PPE items catalog'
}

// ===============================================
// DETECTION SYSTEM MODULE
// ===============================================

Table detections {
  id uuid [pk, increment]
  detection_code varchar(100) [unique, not null]
  camera_id uuid [not null, ref: > cameras.id]
  zone_id uuid [not null, ref: > zones.id]
  plant_id uuid [not null, ref: > plants.id]
  timestamp timestamp [not null, default: `now()`]
  status varchar(20) [not null, note: 'compliant, violation, warning']
  confidence_score decimal(5,2) [not null, note: '0-100']
  person_count int [default: 1]
  image_url varchar(512)
  image_path varchar(512)
  thumbnail_url varchar(512)
  video_clip_url varchar(512)
  metadata json
  bbs_score decimal(5,2) [note: 'Behavior-Based Safety score']
  processed_at timestamp
  reviewed_by uuid [ref: > users.id]
  reviewed_at timestamp
  review_notes text
  is_false_positive boolean [default: false]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    detection_code [unique]
    camera_id
    zone_id
    plant_id
    timestamp
    status
    (plant_id, timestamp)
    (zone_id, timestamp)
  }

  Note: 'Main PPE detection events'
}

Table detection_items {
  id uuid [pk, increment]
  detection_id uuid [not null, ref: > detections.id]
  ppe_item_id uuid [not null, ref: > ppe_items.id]
  is_detected boolean [not null, note: 'true if detected, false if missing']
  confidence decimal(5,2) [not null, note: '0-100']
  bounding_box json [note: '{x, y, width, height}']
  created_at timestamp [default: `now()`]

  Indexes {
    detection_id
    ppe_item_id
    (detection_id, ppe_item_id) [unique]
  }

  Note: 'PPE items detected or missing in each detection'
}

// ===============================================
// INCIDENT MANAGEMENT MODULE
// ===============================================

Table incidents {
  id uuid [pk, increment]
  incident_code varchar(100) [unique, not null]
  detection_id uuid [not null, ref: > detections.id]
  plant_id uuid [not null, ref: > plants.id]
  zone_id uuid [not null, ref: > zones.id]
  incident_type varchar(50) [not null, note: 'ppe_violation, unsafe_behavior, near_miss']
  severity varchar(20) [not null, note: 'low, medium, high, critical']
  title varchar(255) [not null]
  description text
  root_cause text
  corrective_action text
  status varchar(20) [default: 'open', note: 'open, in_progress, resolved, closed']
  assigned_to uuid [ref: > users.id]
  reported_by uuid [ref: > users.id]
  resolved_by uuid [ref: > users.id]
  resolved_at timestamp
  resolution_notes text
  priority int [default: 0]
  due_date timestamp
  occurred_at timestamp [not null]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    incident_code [unique]
    detection_id
    plant_id
    zone_id
    status
    severity
    assigned_to
    (plant_id, occurred_at)
  }

  Note: 'Safety incidents requiring action'
}

Table alerts {
  id uuid [pk, increment]
  alert_code varchar(100) [unique, not null]
  incident_id uuid [ref: > incidents.id]
  detection_id uuid [ref: > detections.id]
  plant_id uuid [not null, ref: > plants.id]
  zone_id uuid [ref: > zones.id]
  alert_type varchar(50) [not null, note: 'violation, camera_offline, system_error, threshold_breach']
  severity varchar(20) [not null, note: 'low, medium, high, critical']
  title varchar(255) [not null]
  message text [not null]
  status varchar(20) [default: 'active', note: 'active, acknowledged, resolved, dismissed']
  acknowledged_by uuid [ref: > users.id]
  acknowledged_at timestamp
  resolved_at timestamp
  recipients json [note: 'Array of user IDs']
  notification_sent boolean [default: false]
  notification_method varchar(50) [note: 'email, sms, push, in_app']
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    alert_code [unique]
    incident_id
    detection_id
    plant_id
    zone_id
    status
    alert_type
    severity
    created_at
  }

  Note: 'System alerts and notifications'
}

// ===============================================
// ANALYTICS & REPORTING MODULE
// ===============================================

Table reports {
  id uuid [pk, increment]
  report_code varchar(100) [unique, not null]
  plant_id uuid [ref: > plants.id]
  report_type varchar(50) [not null, note: 'daily, weekly, monthly, custom, incident']
  title varchar(255) [not null]
  description text
  period_start timestamp [not null]
  period_end timestamp [not null]
  generated_by uuid [not null, ref: > users.id]
  status varchar(20) [default: 'pending', note: 'pending, generating, completed, failed']
  file_path varchar(512)
  file_url varchar(512)
  file_format varchar(10) [note: 'pdf, excel, csv']
  file_size_kb int
  metrics json
  filters json
  generated_at timestamp
  downloaded_count int [default: 0]
  last_downloaded_at timestamp
  expires_at timestamp
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    report_code [unique]
    plant_id
    report_type
    generated_by
    status
    (plant_id, period_start, period_end)
  }

  Note: 'Generated analytical reports'
}

Table audit_logs {
  id uuid [pk, increment]
  user_id uuid [ref: > users.id]
  action varchar(100) [not null, note: 'create, update, delete, login']
  entity_type varchar(50) [not null]
  entity_id uuid
  old_values json
  new_values json
  ip_address varchar(45)
  user_agent text
  plant_id uuid [ref: > plants.id]
  status varchar(20) [note: 'success, failed']
  error_message text
  timestamp timestamp [default: `now()`]

  Indexes {
    user_id
    entity_type
    entity_id
    timestamp
    plant_id
    (entity_type, entity_id)
    (user_id, timestamp)
  }

  Note: 'System audit trail'
}

// ===============================================
// CONFIGURATION MODULE
// ===============================================

Table system_settings {
  id uuid [pk, increment]
  key varchar(100) [unique, not null]
  value text [not null]
  data_type varchar(20) [not null, note: 'string, number, boolean, json']
  category varchar(50) [note: 'detection, alerts, reports, system']
  description text
  is_encrypted boolean [default: false]
  is_system boolean [default: false]
  updated_by uuid [ref: > users.id]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    key [unique]
    category
  }

  Note: 'System configuration settings'
}

Table notification_preferences {
  id uuid [pk, increment]
  user_id uuid [unique, not null, ref: > users.id]
  email_enabled boolean [default: true]
  sms_enabled boolean [default: false]
  push_enabled boolean [default: true]
  in_app_enabled boolean [default: true]
  alert_severity_threshold varchar(20) [default: 'medium']
  alert_types json
  quiet_hours_start time
  quiet_hours_end time
  timezone varchar(50) [default: 'Asia/Kolkata']
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    user_id [unique]
  }

  Note: 'User notification preferences'
}

// ===============================================
// DASHBOARD STATISTICS
// ===============================================

Table dashboard_stats {
  id uuid [pk, increment]
  plant_id uuid [not null, ref: > plants.id]
  date date [not null]
  hour int [note: '0-23 for hourly, NULL for daily']
  total_detections int [default: 0]
  compliant_count int [default: 0]
  violation_count int [default: 0]
  warning_count int [default: 0]
  compliance_rate decimal(5,2)
  bbs_score_avg decimal(5,2)
  incidents_count int [default: 0]
  critical_incidents_count int [default: 0]
  cameras_active int [default: 0]
  cameras_total int [default: 0]
  uptime_percentage decimal(5,2)
  unique_zones_count int [default: 0]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]

  Indexes {
    plant_id
    date
    (plant_id, date, hour) [unique]
  }

  Note: 'Pre-calculated dashboard stats for performance'
}
